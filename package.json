{
  "name": "csc-scholarship-repo",
  "version": "1.0.0",
  "private": true,
  "description": "Tracking repository for CSC scholarship documents, deadlines, and university professor research data.",
  "scripts": {
    "build:xlsx": "powershell -ExecutionPolicy Bypass -File scripts/export-xlsx.ps1",
    "collect:professors": "node scripts/collect-professor-data.mjs",
    "build:database": "node scripts/build-program-database.mjs",
    "seed:professor-queue": "node scripts/seed-professor-queue.mjs",
    "snapshot:professors": "node scripts/generate-professor-snapshot.mjs",
    "report:professors": "node scripts/report-professor-status.mjs"
  }
}
